{
  // Renderer (browser context) + the test suite (renderer tests use jsdom/RTL; service
  // tests import main code, which type-checks fine here too). DOM lib is available.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx"
  },
  "include": ["src/renderer", "tests"]
}
