# Generated by `xtask gen-ninja` — do not edit by hand.
# Make is the entrypoint; it calls `nix run .#xtask -- build <target>`.

rule stamp
  command = mkdir -p dist/.ninja && $cmd && touch $out
  description = $desc

rule gen
  command = $cmd
  description = $desc

