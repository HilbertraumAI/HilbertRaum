# Dependencies
node_modules/

# External SSD Volume Data
System Volume Information/

#deepsec
.deepsec

#local claude skills
.claude

# Build output
dist/
out/
release/
*.tsbuildinfo

# Test coverage output (npm run test:coverage) — generated, never committed
coverage/

# Model weights — NEVER commit (spec rule 0.1.8 / 0.2)
models/
*.gguf
*.onnx
*.safetensors
*.bin

# User data / workspace — stays local, never committed
workspace/
# Local-only real-data gold sets (PDF geometry-extraction D57): real bank statements + their
# hand-counted expectations. NEVER commit — only the harness + README under tests/real-data/ are
# tracked, and the harness prints aggregate metrics only.
apps/desktop/tests/real-data/corpus/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
*.db-journal

# Logs
logs/
*.log

# Drive runtime binaries (sidecars) — the DRIVE's runtime/ dir only.
# Anchored to the repo root so it does NOT match the source tree's
# apps/desktop/src/main/services/runtime/ (that bug silently un-tracked the runtime service).
/runtime/

# OCR language data (Phase 38) — vendored onto the drive at build time, never committed
# (the never-commit-model-assets rule). Anchored: the source tree has services/ocr/.
/ocr/

# Code-signing secrets (Phase 13) — NEVER commit certs/keys/credentials.
# Signing is driven by env vars / a local, git-ignored secrets file on the build machine.
*.pfx
*.p12
*.cer
*.key
*.keychain
signing.env
*.provisionprofile

# Env / OS
.env
.env.*
.DS_Store
Thumbs.db
apps/desktop/screenshots/
